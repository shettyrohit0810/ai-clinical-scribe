# Local development only. Copy to .env (git-ignored — see /.gitignore).
# Production does NOT use a .env file: the systemd unit sets AWS_SECRET_NAME
# and app/config.py pulls this same key set from AWS Secrets Manager via the
# EC2 instance role. See infra/DEPLOY.md.
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://scribe:scribe@localhost:5433/scribe
# Any non-trivial string for local dev; production uses a generated value in
# Secrets Manager (the app refuses to start in prod on the dev default).
JWT_SECRET=dev-insecure-jwt-secret-do-not-use-in-prod
# Required for real note generation and voice editing (console.anthropic.com).
# Safe to leave empty: the app boots and tests run (LLM is mocked), but every
# real generation returns a graceful error until a key is set.
ANTHROPIC_API_KEY=
